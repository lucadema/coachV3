# Aether Glimpse Admin Control Panel environment
#
# Copy the relevant values into your deployment environment. Do not commit real
# secrets. ADMIN_DATABASE_URL may be omitted when TELEMETRY_DATABASE_URL already
# points at the shared Glimpse database.

ADMIN_API_TOKEN=replace-with-a-long-random-admin-secret
ADMIN_DATABASE_URL=postgresql://user:password@host:5432/database
ADMIN_ENVIRONMENT=local

GLIMPSE_ACCESS_URL_TEMPLATE=http://localhost:5173/?t={token}
DASHBOARD_ACCESS_URL_TEMPLATE=http://localhost:5175/?t={token}

ADMIN_CORS_ALLOW_ORIGINS=http://localhost:5174

